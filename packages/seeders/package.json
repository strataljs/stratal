{
  "name": "@stratal/seeders",
  "version": "0.0.7",
  "description": "Database seeder infrastructure for Stratal framework applications",
  "type": "module",
  "license": "MIT",
  "author": "Temitayo Fadojutimi",
  "homepage": "https://github.com/strataljs/stratal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strataljs/stratal.git",
    "directory": "packages/seeders"
  },
  "bugs": {
    "url": "https://github.com/strataljs/stratal/issues"
  },
  "keywords": [
    "stratal",
    "seeders",
    "database",
    "cloudflare-workers"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "stratal-seed": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint --fix ."
  },
  "dependencies": {
    "@swc-node/register": "^1.11.1",
    "chalk": "^5.6.2",
    "reflect-metadata": "^0.2.2",
    "wrangler": "^4.71.0",
    "yargs": "^18.0.0"
  },
  "peerDependencies": {
    "stratal": "^0.0.7"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/node": "^25.3.5",
    "@types/yargs": "^17.0.35",
    "stratal": "workspace:*",
    "typescript": "^5.9.3"
  }
}
