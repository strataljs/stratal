{
  "name": "stratal-example-12-database",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-25",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ENVIRONMENT": "development"
  },
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "placeholder"
    }
  ],
  "hyperdrive": [
    {
      "binding": "DB",
      "id": "placeholder",
      "localConnectionString": "postgres://stratal:stratal@localhost:6432/stratal_database_example"
    }
  ]
}
